# ─── Scheduler / cron interno ───────────────────────────────────────────────
# Liga o scheduler interno do processo Node (PM2/VM). Em Vercel use INTERNAL_CRON_RUN_ON_VERCEL=true
# ou desligue isto e use as rotas /api/cron/* via Vercel Cron.
INTERNAL_CRON_ENABLED=true
# Permite rodar o scheduler interno em Vercel mesmo sabendo que o processo morre. Default false.
# INTERNAL_CRON_RUN_ON_VERCEL=true

# Secret dos GET /api/cron/* (realtime-tick, daily-full-sync).
CRON_SECRET=3a1afa46821bce3a481077903cb49cdead7dddaa75d0523b698f86e5ad86a2c7

# ─── Realtime worker (1 min) ────────────────────────────────────────────────
# Intervalo entre ticks do worker (segundos). Default 60.
REALTIME_WORKER_INTERVAL_SECONDS=60
# Janela após apito em que o jogo permanece elegível ao worker (min). Default 180.
REALTIME_WORKER_WINDOW_MINUTES=180
# Margem antes do apito para começar a consultar (min). Default 5.
REALTIME_WORKER_PRE_KICKOFF_MINUTES=5
# Cap de chamadas /partidas/:id por tick. Default 20.
REALTIME_WORKER_MAX_PER_TICK=20

# TTL do MatchMap em memória (ms). Default 180000 (3 min).
# MATCH_MAP_MEMORY_TTL_MS=180000

# ─── Indicações / afiliados ─────────────────────────────────────────────────
REFERRAL_REWARD_BRONZE_CENTS=800
REFERRAL_REWARD_SILVER_CENTS=1000
REFERRAL_REWARD_GOLD_CENTS=1200
REFERRAL_REWARD_DIAMOND_CENTS=1500
REFERRAL_TIER_SILVER_MIN_COMMISSIONS=10
REFERRAL_TIER_GOLD_MIN_COMMISSIONS=25
REFERRAL_TIER_DIAMOND_MIN_COMMISSIONS=50
AFFILIATE_MIN_WITHDRAWAL_CENTS=2000

# ─── Loja / vitrine ─────────────────────────────────────────────────────────
