# ─── Produção: https://bolaodomilhao.com ─────────────────────────────────────
# Use como referência no Vercel (Environment Variables) ou copie valores seguros
# para um .env local de deploy. Não commite arquivos .env com segredos reais.
#
# Domínio canônico: https://bolaodomilhao.com (sem barra no final em APP_URL).
# Se também usar https://www.bolaodomilhao.com, configure redirect 301 → apex
# no DNS/hosting e mantenha APP_URL igual ao domínio onde a app “morar” de fato.
#
# NODE_ENV=production o Vercel define sozinho no build/runtime.

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_SSL=true
# DATABASE_URL=

# Segredo JWT do cookie de sessão (mín. 32 caracteres): openssl rand -base64 32
AUTH_SECRET=

# URL pública = domínio de produção (OAuth, links de retorno PIX, etc.)
APP_URL=https://bolaodomilhao.com

# Google OAuth — Authorized redirect URI exatamente:
# https://bolaodomilhao.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Ticket / PIX (Skale) ───────────────────────────────────────────────────
TICKET_PRICE_GENERAL_CENTS=5000
TICKET_PRICE_DAILY_CENTS=2500

SKALE_API_URL=https://api.skalepayments.com.br
SKALE_API_KEY=

# URL que a Skale chama quando o pagamento muda de status (HTTPS público)
SKALE_POSTBACK_URL=https://bolaodomilhao.com/api/webhooks/skale
SKALE_WEBHOOK_SECRET=

# ─── API Futebol ──────────────────────────────────────────────────────────────
FOOTBALL_COMPETITION_ID=72
FOOTBALL_API_TOKEN=

# ─── Indicações / afiliados ───────────────────────────────────────────────────
REFERRAL_REWARD_BRONZE_CENTS=800
REFERRAL_REWARD_SILVER_CENTS=1000
REFERRAL_REWARD_GOLD_CENTS=1200
REFERRAL_REWARD_DIAMOND_CENTS=1500
REFERRAL_TIER_SILVER_MIN_COMMISSIONS=10
REFERRAL_TIER_GOLD_MIN_COMMISSIONS=25
REFERRAL_TIER_DIAMOND_MIN_COMMISSIONS=50
AFFILIATE_MIN_WITHDRAWAL_CENTS=2000
