# Copie para ".env" na raiz do projeto e preencha os valores.
# cp .env.example .env
#
# Teste de conexão (com `npm run dev` rodando): https://SEU_DOMINIO/api/db/test
# ou: npm run db:test
#
# Schema do banco (tabela users / auth): scripts/auth-schema.sql
# Migração nome obrigatório (banco já existente): scripts/migrate-users-name-not-null.sql
# Migração afiliados (código + quem indicou): scripts/migrate-users-affiliates.sql
# Criar no PostgreSQL: psql "$DATABASE_URL" -f scripts/auth-schema.sql
# Fluxo de tickets/transacoes PIX: psql "$DATABASE_URL" -f scripts/payments-schema.sql
# Palpites persistentes: psql "$DATABASE_URL" -f scripts/predictions-schema.sql
# Indicações / comissões e saques afiliados: psql "$DATABASE_URL" -f scripts/affiliate-schema.sql
# (com variáveis separadas: export PGHOST PGPORT PGUSER PGPASSWORD PGDATABASE e rode psql -f ...)

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# Recomendado: host, usuário, senha e banco em campos separados.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=bolao_milhao
# "true" se o servidor exigir SSL
DATABASE_SSL=false

# Alternativa: uma única URL (encode caracteres especiais na senha)
# DATABASE_URL=postgresql://user:senha@host:5432/bolao_milhao

# Segredo para assinar o cookie de sessão (mínimo 32 caracteres; gere com: openssl rand -base64 32)
AUTH_SECRET=
# AUTH_DEBUG=1 — logs extras em /api/auth/me (ex.: visita sem cookie de sessão)

# URL pública da aplicação (sem barra no final). Usada no redirect do Google OAuth.
APP_URL=http://localhost:3000

# Google OAuth — Console: https://console.cloud.google.com/apis/credentials
# Passo a passo completo: lib/google/README.md
# Authorized redirect URI: {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Ticket / Deposito (PIX - Skale) ─────────────────────────────────────────
# Preco em centavos
TICKET_PRICE_GENERAL_CENTS=3990
TICKET_PRICE_DAILY_CENTS=2000
TICKET_PRICE_EXTRA_CENTS=3990

# Gateway
SKALE_API_URL=https://api.skalepayments.com.br
SKALE_API_KEY=
# Webhook recebido apos atualizacao de status no gateway
SKALE_POSTBACK_URL=https://SEU_DOMINIO/api/webhooks/skale
# Opcional: enviar o mesmo valor no header x-webhook-secret do webhook
SKALE_WEBHOOK_SECRET=

# ─── API Futebol (partidas / tabela) ───────────────────────────────────────
# ID do campeonato na API Futebol (https://www.api-futebol.com.br)
FOOTBALL_COMPETITION_ID=72
# IDs extras (API-Futebol), separados por vírgula — cada um vira um bolão extra (R$ 10 / mesma lógica do dia).
# BOLOES_EXTRA_CHAMPIONSHIP_IDS=2,3
# Preço unitário dos tickets extra (centavos). Default 1000 = R$ 10,00.
# TICKET_PRICE_EXTRA_BOLAO_CENTS=1000
# Opcional: duplicar IDs no client (a página /tickets já envia BOLOES_EXTRA_* do servidor no primeiro paint).
# NEXT_PUBLIC_BOLOES_EXTRA_CHAMPIONSHIP_IDS=2,3
FOOTBALL_API_TOKEN=
# Limite de rodadas ao buscar detalhe por rodada (sync / merge de placar)
# FOOTBALL_ROUNDS_SYNC_LIMIT=80
# Só use em emergência: enriquecimento por GET /rodadas + N detalhes na API em cada sync (alto consumo de cota).
# FOOTBALL_ROUNDS_LIVE_ENRICH=false
# FOOTBALL_FASES_SYNC_LIMIT=32
# Maximo de GET /v1/partidas/{id} por sync quando falta placar (merge apos bulk)
# FOOTBALL_PARTIDA_DETAIL_LOOKUP_LIMIT=16
# Tabela e enriquecimento de fases (mata-mata) vêm da tabela `football_api_cache` (scripts/sql/add-football-api-cache.sql).
# Atualização diária (BRT): tick interno na janela 00:00–00:15 ou 01:00–01:15 (snapshot tabela+fases + sync partidas), ou GET /api/cron/football-snapshots?secret=CRON_SECRET (mesmo pipeline).
# Primeira subida sem cache: warmup chama snapshot uma vez se FOOTBALL_API_TOKEN estiver definido.

# Garantia de placar (horas apos apito sem placar + palpite)
# MATCH_RESULT_GUARANTEE_HOURS_AFTER_KICKOFF=3
# Minutos apos apito: assume fim do jogo no relogio — forca sync com palpite sem placar (default ~1h55)
# MATCH_END_CLOCK_AFTER_KICKOFF_MINUTES=115
# Tick 5 min: partidas na API se cache velho N min em jogo iniciado nas ultimas 48h (ou garantia)
# MATCH_CRON_STALE_REFRESH_MINUTES=10
# Apos apito + N min: se ainda nao houve sync desde esse marco, forca refresh (placar ao vivo)
# MATCH_POST_KICKOFF_FIRST_SYNC_MINUTES=10

# Cache de partidas no Postgres (preenchido por cron / warmup; GET /api/partidas só le aqui)
# Sync com a API no tick só quando há pendência (ver MATCH_CRON_* e lib/cron/match-result-guarantee.ts).
MATCHES_CACHE_TTL_SECONDS=120
MATCHES_CACHE_IDLE_SYNC_SECONDS=900
MATCHES_CACHE_ACTIVE_SYNC_SECONDS=120
MATCHES_CACHE_PRE_KICKOFF_WINDOW_MINUTES=30
# Intervalo minimo entre soft-syncs legados (ms); GET /api/partidas nao agenda mais sync
# MATCHES_SOFT_SYNC_MIN_INTERVAL_MS=600000
# TTL do mapa em memoria em fetchMatchesMap (ms) — só leitura do Postgres
# MATCH_MAP_MEMORY_TTL_MS=180000

# ─── Cron / scheduler interno (Node / PM2) ──────────────────────────────────
# Secret para GET /api/cron/sync-partidas, /api/cron/garantia-resultados, /api/cron/tick (?secret= ou Bearer)
CRON_SECRET=
# Scheduler no proprio processo (instrumentation). Em Vercel desliga salvo INTERNAL_CRON_RUN_ON_VERCEL=true.
INTERNAL_CRON_ENABLED=true
INTERNAL_CRON_RUN_ON_VERCEL=false
# Tick a cada N segundos: pipeline noturno (se janela BRT), sync condicional partidas na API, garantia + premios. 300 = 5 min.
INTERNAL_CRON_TICK_SECONDS=300
# Se INTERNAL_CRON_TICK_SECONDS nao existir, usa este (legado).
# INTERNAL_CRON_SYNC_MATCHES_SECONDS=300

# Depois do apito: horas ate forcar sync se ainda sem placar (com palpite)
MATCH_RESULT_GUARANTEE_HOURS_AFTER_KICKOFF=3
# Depois do apito: minutos no relogio (now vs kickoff_at) para assumir jogo encerrado e forcar sync se sem placar
MATCH_END_CLOCK_AFTER_KICKOFF_MINUTES=150

# Premiacao automatica (apos sync de partidas / tick do cron, idempotente)
# Diario: so fecha o dia quando todos os jogos da data tem placar (ou cancel/...) E passou X min apos o apito do ultimo jogo daquele dia.
# PRIZE_DAILY_GRACE_AFTER_LAST_KICKOFF_MINUTES=180
# Geral: so quando nao ha jogo com kickoff no futuro no cache, todos resolvidos, e passou Y horas apos o ultimo apito da competicao (fim da Copa no cache).
# PRIZE_GENERAL_GRACE_HOURS_AFTER_LAST_KICKOFF=36

# Log de debug do sync de partidas (1 / true / yes)
DEBUG_MATCHES_SYNC=false
# Log de cada HTTP para api.api-futebol.com.br (path, status, ms). Se omitir, DEBUG_MATCHES_SYNC=1 também liga estes logs.
# DEBUG_FOOTBALL_API=true

# ─── Indicações (comissão após PIX do indicado pago) ─────────────────────────
# Valores em centavos por indicação paga, conforme a N-ésima comissão do afiliado:
# 1..(SILVER-1)=bronze, SILVER..(GOLD-1)=prata, GOLD..(DIAMOND-1)=ouro, DIAMOND+=diamante
REFERRAL_REWARD_BRONZE_CENTS=800
REFERRAL_REWARD_SILVER_CENTS=1000
REFERRAL_REWARD_GOLD_CENTS=1200
REFERRAL_REWARD_DIAMOND_CENTS=1500
REFERRAL_TIER_SILVER_MIN_COMMISSIONS=10
REFERRAL_TIER_GOLD_MIN_COMMISSIONS=25
REFERRAL_TIER_DIAMOND_MIN_COMMISSIONS=50
# Mínimo para solicitar saque (centavos), ex.: 2000 = R$ 20,00
AFFILIATE_MIN_WITHDRAWAL_CENTS=2000

# ─── Deploy automático (webhook GitHub → build → pm2) ───────────────────────
# No GitHub: Settings → Webhooks → Add webhook
#   Payload URL: https://SEU_DOMINIO/api/webhooks/github-deploy
#   Content type: **application/json** (recomendado) ou application/x-www-form-urlencoded (também suportado: campo `payload`)
#   Events: "Just the push event"
# Fluxo (como Vercel): você faz git push na branch → GitHub POST aqui → servidor: git pull, npm install, build, pm2.
# (A rota não valida secret — restrinja por IP/firewall se precisar.)
# No servidor: clone com git, chave SSH ou HTTPS com credencial, e pm2 no PATH.
# Obrigatório na VM típica (PM2 pode não ter cwd na pasta do repo): pasta do clone = onde roda git pull.
# Ex.: app em /root/app → use caminho absoluto
DEPLOY_APP_ROOT=/root/app
# Branch que o servidor atualiza (default main). Só faz deploy se ref == refs/heads/<branch>
GITHUB_DEPLOY_BRANCH=main
# Opcional: sobrescreve a ref exata (ex.: refs/heads/production)
# GITHUB_DEPLOY_REF=
# Opcional: arquivo de log (default ./logs/github-deploy.log)
# DEPLOY_LOG_FILE=
# Opcional: 1 = não faz git pull (só build + pm2; npm install só se faltar node_modules)
# SKIP_GIT_PULL=0
# Opcional: 1 = sempre roda npm install antes do build
# FORCE_NPM_INSTALL=0
# Opcional: token para GET /api/webhooks/github-deploy?token=... ver últimas linhas do log (texto)
# DEPLOY_DEBUG_TOKEN=
