# Copie para ".env" na raiz e preencha os valores:
#   cp .env.example .env
#
# Migrations obrigatórias (ver scripts/sql/):
#   psql "$DATABASE_URL" -f scripts/sql/20260516-tickets-promo-bonus.sql
#   psql "$DATABASE_URL" -f scripts/sql/20260516-registration-sms-codes.sql
#   psql "$DATABASE_URL" -f scripts/sql/20260517-performance-indexes.sql
#   psql "$DATABASE_URL" -f scripts/sql/20260519-arquitetura-bolao-v2.sql   ← obrigatória v2
#
# Documentação:
#   README.md            — arquitetura, fluxos, env, comandos
#   docs/TICKETS.md      — fluxo completo de tickets, palpites, resultados, prêmios

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=bolao_milhao
DATABASE_SSL=false
# Opcional: mesma conexão em uma linha. Com DATABASE_HOST preenchido, a app Node ainda usa
# DATABASE_HOST + DATABASE_USER + ... (prioridade em lib/db.ts). Isto serve para CLI:
#   set -a && source .env && set +a && psql "$DATABASE_URL" -f scripts/sql/....sql
# Produção remota com SSL:
# DATABASE_URL=postgresql://user:senha@host:5432/bolao_milhao?sslmode=require
# Se `psql "$DATABASE_URL"` pedir "Password for user root", DATABASE_URL está vazio — carregue o .env.
# Índices: npm run db:indexes

# ─── App / sessão ───────────────────────────────────────────────────────────
# Mínimo 32 chars; produção: openssl rand -base64 48
AUTH_SECRET=
APP_URL=http://localhost:3000

# Google OAuth (redirect: {APP_URL}/api/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Validação CPF no cadastro (https://api.cpf-brasil.org)
CPF_BRASIL_API_KEY=

# ─── Tickets / PIX (Skale) ──────────────────────────────────────────────────
TICKET_PRICE_GENERAL_CENTS=3990
TICKET_PRICE_DAILY_CENTS=2000
TICKET_PRICE_EXTRA_CENTS=3990
TICKET_PRICE_EXTRA_BOLAO_CENTS=1000

SKALE_API_URL=https://api.skalepayments.com.br
SKALE_API_KEY=
SKALE_POSTBACK_URL=https://SEU_DOMINIO/api/webhooks/skale
SKALE_WEBHOOK_SECRET=

# POST JSON quando PIX de ticket é aprovado pela primeira vez (opcional)
# PAYMENT_APPROVED_WEBHOOK_URL=https://seu-sistema.com/webhooks/pagamento-aprovado
# PAYMENT_APPROVED_WEBHOOK_SECRET=
# PAYMENT_APPROVED_WEBHOOK_TIMEOUT_MS=12000

# Loja
TICKETS_EXTRA_ONLY=false
TICKETS_HIDE_DAILY=false
COPA_BONUS_EXTRA_PROMO_ENABLED=true
# COPA_BONUS_EXTRA_PROMO_CHAMPIONSHIP_ID=10
# NEXT_PUBLIC_BOLOES_EXTRA_CHAMPIONSHIP_IDS=10

# ─── API Futebol (cron diário + worker realtime — arquitetura v2) ────────────
# Token: https://www.api-futebol.com.br
FOOTBALL_API_TOKEN=
# Campeonato principal (bolão geral + diário)
FOOTBALL_COMPETITION_ID=72
# Lista CSV de campeonatos extras (Brasileirão etc.)
BOLOES_EXTRA_CHAMPIONSHIP_IDS=10

# Logs de cada GET na API Futebol (path + status + ms)
# DEBUG_FOOTBALL_API=true

# ─── Scheduler / cron ───────────────────────────────────────────────────────
# Token dos GET /api/cron/realtime-tick, /api/cron/daily-full-sync
CRON_SECRET=

# Scheduler interno no processo Node (PM2/VM). Em Vercel desligado por padrão.
INTERNAL_CRON_ENABLED=true
# Forçar scheduler interno em Vercel (não recomendado — processo serverless)
# INTERNAL_CRON_RUN_ON_VERCEL=false

# ─── Realtime worker (1 min) ────────────────────────────────────────────────
REALTIME_WORKER_INTERVAL_SECONDS=60
REALTIME_WORKER_WINDOW_MINUTES=180
REALTIME_WORKER_PRE_KICKOFF_MINUTES=5
REALTIME_WORKER_MAX_PER_TICK=20
# Desliga locks Postgres no full sync / realtime tick (só debug; em cluster mantenha comentado).
# FOOTBALL_ADVISORY_LOCKS_DISABLED=true

# TTL do MatchMap em memória (ms). Default 180000 (3 min).
# MATCH_MAP_MEMORY_TTL_MS=180000

# Debug-only em /boloes (não afeta o worker; usado só por rendering)
# MATCH_END_CLOCK_AFTER_KICKOFF_MINUTES=115

# ─── Premiação ──────────────────────────────────────────────────────────────
# PRIZE_DAILY_GRACE_AFTER_LAST_KICKOFF_MINUTES=180
# PRIZE_GENERAL_GRACE_HOURS_AFTER_LAST_KICKOFF=36

# ─── Indicações / afiliados ─────────────────────────────────────────────────
REFERRAL_REWARD_BRONZE_CENTS=800
REFERRAL_REWARD_SILVER_CENTS=1000
REFERRAL_REWARD_GOLD_CENTS=1200
REFERRAL_REWARD_DIAMOND_CENTS=1500
REFERRAL_TIER_SILVER_MIN_COMMISSIONS=10
REFERRAL_TIER_GOLD_MIN_COMMISSIONS=25
REFERRAL_TIER_DIAMOND_MIN_COMMISSIONS=50
AFFILIATE_MIN_WITHDRAWAL_CENTS=2000

# ─── Hosts / domínio ────────────────────────────────────────────────────────
SUBDOMAIN_ROUTING_ENABLED=false
# SITE_DOMAIN=bolaodomilhao.com.br
# NEXT_PUBLIC_SITE_DOMAIN=bolaodomilhao.com.br
MARKETING_URL=http://localhost:3000
LOCAL_DEV_AS_APP=false
NEXT_PUBLIC_LOCAL_DEV_AS_APP=false
NEXT_PUBLIC_MARKETING_HOST=www.localhost
# Produção:
# SUBDOMAIN_ROUTING_ENABLED=true
# SITE_DOMAIN=bolaodomilhao.com.br
# NEXT_PUBLIC_SITE_DOMAIN=bolaodomilhao.com.br
# APP_URL=https://app.bolaodomilhao.com.br
# MARKETING_URL=https://www.bolaodomilhao.com.br
# NEXT_PUBLIC_APP_URL=https://app.bolaodomilhao.com.br
# NEXT_PUBLIC_MARKETING_URL=https://www.bolaodomilhao.com.br

# ─── Deploy automático (GitHub webhook → build → pm2) ───────────────────────
# Webhook: https://SEU_DOMINIO/api/webhooks/github-deploy
DEPLOY_APP_ROOT=/root/app
GITHUB_DEPLOY_BRANCH=main
# GITHUB_DEPLOY_REF=
# DEPLOY_LOG_FILE=
# SKIP_GIT_PULL=0
# FORCE_NPM_INSTALL=0
# DEPLOY_DEBUG_TOKEN=
